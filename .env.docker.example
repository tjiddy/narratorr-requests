# Copy to .env (next to docker-compose.yml) for a REAL deployment, then `docker compose up -d`.
# docker-compose.yml reads these via ${VAR} interpolation. Anything left unset falls back
# to the smoke defaults baked into the compose file.
#
# NOTE: the narratorr connection and notification channels (ntfy / email / webhook) are
# NOT environment variables — configure them in the admin Settings page after first boot.
# They're stored encrypted in the DB. Env here covers only server + auth + secrets.

# Host port to publish (container always listens on 3000 internally).
PORT=3000
TZ=America/New_York

# --- Production posture ---
NODE_ENV=production
AUTH_BYPASS=0
ALLOW_INSECURE_AUTH_BYPASS=0
# REQUIRED in production. Generate one: `openssl rand -hex 32`
SESSION_SECRET=

# Key for encrypting connector secrets (narratorr API key, SMTP password, ntfy token)
# at rest. Optional — when unset it's derived from SESSION_SECRET. RECOMMENDED to set a
# dedicated one: otherwise rotating SESSION_SECRET makes every stored connector secret
# unreadable (the app logs a WARN and treats those connectors as unconfigured until you
# re-enter them in Settings). Generate one: `openssl rand -hex 32`
SETTINGS_KEY=

# Docker-secrets convention: instead of the plain SESSION_SECRET / SETTINGS_KEY above, point
# <NAME>_FILE at a mounted (:ro) file whose contents become the value — so the secret never
# enters the container environment (not visible via `docker inspect` / `/proc/<pid>/environ`).
# Mount the file and reference it (e.g. via compose `secrets:` → /run/secrets/<name>). Contents
# are trimmed; <NAME>_FILE takes precedence over the plain var; an explicitly-set _FILE that is
# unreadable or empty fails fast at startup. Supported: SESSION_SECRET_FILE, SETTINGS_KEY_FILE,
# and OIDC_<ID>_CLIENT_SECRET_FILE (see OIDC below).
# SESSION_SECRET_FILE=/run/secrets/session_secret
# SETTINGS_KEY_FILE=/run/secrets/settings_key

# The browser hits the app on the same origin it's served from. Set to your public URL.
CORS_ORIGIN=https://requests.example.com

# Behind a reverse proxy (Caddy/Traefik/nginx), trust X-Forwarded-* so the real client IP is
# used for auth rate-limiting. Same var name as narratorr. Set true, a hop count, or a
# CIDR/IP list (e.g. your Docker proxy network).
TRUSTED_PROXIES=172.18.0.0/16

# Is there TLS in front of the app? Drives the HTTPS-assuming security surfaces: the CSP
# `upgrade-insecure-requests` directive, the HSTS header, and the `Secure` session cookie.
# Defaults ON because NODE_ENV=production above (the usual "behind a TLS-terminating proxy"
# topology). Set BEHIND_TLS=false ONLY if you run this prod image over PLAIN HTTP with no TLS
# terminator (LAN/VPN/Tailscale) — otherwise assets fail with ERR_SSL_PROTOCOL_ERROR (blank
# page) and login won't persist (the browser drops the Secure cookie over http://).
# BEHIND_TLS=false

# --- Authentication (with AUTH_BYPASS=0) ---
# Pick at least one method. The first user to sign in becomes admin + active; everyone
# after lands `pending` until an admin approves them on the Users page. For a public/open
# IdP, set BOOTSTRAP_ADMIN so a stranger can't claim admin by being first.

# Local email/password auth (email is the login + contact). Default ON. Set false for pure-OIDC.
LOCAL_AUTH=true

# OIDC providers: comma-separated ids, each configured via OIDC_<UPPERCASE_ID>_* below.
# Each provider's redirect URI must be the public /api/auth/oidc/<id>/callback URL.
# OIDC_PROVIDERS=plex,authelia

# Plex (via ghcr.io/blacktirion/plex-oidc-bridge):
# OIDC_PLEX_ISSUER=
# OIDC_PLEX_CLIENT_ID=narratorr-requests
# OIDC_PLEX_CLIENT_SECRET=
# Or source it from a mounted file (trimmed, takes precedence over the plain var above):
# OIDC_PLEX_CLIENT_SECRET_FILE=/run/secrets/oidc_plex_client_secret
# OIDC_PLEX_REDIRECT_URI=http://localhost:3000/api/auth/oidc/plex/callback
# OIDC_PLEX_LABEL=Plex

# Authelia / Authentik / Keycloak / Pocket-ID / Google (same shape):
# OIDC_AUTHELIA_ISSUER=
# OIDC_AUTHELIA_CLIENT_ID=narratorr-requests
# OIDC_AUTHELIA_CLIENT_SECRET=
# OIDC_AUTHELIA_REDIRECT_URI=http://localhost:3000/api/auth/oidc/authelia/callback
# OIDC_AUTHELIA_LABEL=Authelia

# Pin admin to one identity ("<provider>:<subjectOrUsername>"), disabling first-user-admin:
# BOOTSTRAP_ADMIN=authelia:todd

# The default request quota (limit + day/week/month window) is configured in the admin
# Settings UI, not via env — a fresh DB seeds 10 requests per rolling 30 days.
