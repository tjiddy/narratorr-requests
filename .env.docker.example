# Copy to .env (next to docker-compose.yml) for a REAL deployment, then `docker compose up -d`.
# docker-compose.yml reads these via ${VAR} interpolation. Anything left unset falls back
# to the smoke defaults baked into the compose file.
#
# NOTE: the narratorr connection and notification channels (ntfy / email / webhook) are
# NOT environment variables — configure them in the admin Settings page after first boot.
# They're stored encrypted in the DB. Env here covers only server + auth + secrets.

# Host port to publish (container always listens on 3000 internally).
PORT=3000
TZ=America/New_York

# --- Production posture ---
NODE_ENV=production
AUTH_BYPASS=0
ALLOW_INSECURE_AUTH_BYPASS=0
# REQUIRED in production. Generate one: `openssl rand -hex 32`
SESSION_SECRET=

# Key for encrypting connector secrets (narratorr API key, SMTP password, ntfy token)
# at rest. Optional — when unset it's derived from SESSION_SECRET. RECOMMENDED to set a
# dedicated one: otherwise rotating SESSION_SECRET makes every stored connector secret
# unreadable (the app logs a WARN and treats those connectors as unconfigured until you
# re-enter them in Settings). Generate one: `openssl rand -hex 32`
SETTINGS_KEY=

# The browser hits the app on the same origin it's served from. Set to the public URL.
CORS_ORIGIN=http://localhost:3000

# --- Plex OIDC (required when AUTH_BYPASS=0) ---
PLEX_OIDC_ISSUER=
PLEX_OIDC_CLIENT_ID=narrator-request
PLEX_OIDC_CLIENT_SECRET=
# Must be the public callback URL the bridge redirects to.
PLEX_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
# REQUIRED in production: set the allowlist and/or the owner (who becomes admin).
PLEX_ALLOWLIST=
PLEX_OWNER_USERNAME=

# --- Authelia OIDC (optional operator admin SSO) ---
# AUTHELIA_OIDC_ISSUER=
# AUTHELIA_OIDC_CLIENT_ID=
# AUTHELIA_OIDC_CLIENT_SECRET=
# AUTHELIA_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/authelia/callback
# AUTHELIA_ADMIN_SUBJECT=

# Rolling-30-day request quota for non-admin users (blank/0 = unlimited).
DEFAULT_REQUEST_QUOTA=10
