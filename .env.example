# narrator-request config. Copy to .env for native dev (the server loads it via process.loadEnvFile).
# All values are host-agnostic; inside docker-compose use service hostnames, not localhost.
#
# The narratorr connection and notification channels are NOT configured here — they live
# in the admin Settings page (stored encrypted in the DB). This file is server + auth only.

# Server. PORT is the Fastify port; the Vite dev client also proxies /api to it.
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
# Bind to loopback by default. With AUTH_BYPASS on, the app refuses to bind to a
# non-loopback host (it would expose an unauthenticated admin) unless you also set
# ALLOW_INSECURE_AUTH_BYPASS=1. For real LAN/Docker use, turn AUTH_BYPASS off.
BIND_HOST=127.0.0.1
# Dev client port (Vite). Optional; defaults to 5173.
# CLIENT_PORT=5173

# Database (libSQL file). Anchored to repo root if relative.
DATABASE_PATH=./narrator-request.db

# Session cookie signing secret (HMAC). REQUIRED in production; dev auto-generates an
# ephemeral one if unset (sessions drop on restart — fine for local dev).
# SESSION_SECRET=

# Key for encrypting connector secrets at rest. Optional — derived from SESSION_SECRET
# when unset. Set a dedicated one to decouple connector secrets from session-secret
# rotation (rotating SESSION_SECRET without this orphans stored connector secrets).
# SETTINGS_KEY=

# --- Auth ---
# Dev: AUTH_BYPASS=1 seeds a dev admin and skips Plex OIDC entirely so the whole app is
# usable without the bridge. It makes EVERY request the admin, so it is refused in
# production and refused on non-loopback binds (see BIND_HOST above).
# NEVER set this in a deployment reachable by anyone but you.
AUTH_BYPASS=1

# Plex OIDC (via ghcr.io/blacktirion/plex-oidc-bridge). Required when AUTH_BYPASS is off.
# PLEX_OIDC_ISSUER=http://localhost:5556
# PLEX_OIDC_CLIENT_ID=narrator-request
# PLEX_OIDC_CLIENT_SECRET=
# PLEX_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Comma-separated allowlist of Plex usernames/ids permitted to sign in. In production
# Plex mode you MUST set this or PLEX_OWNER_USERNAME (an empty allowlist would let any
# Plex account sign in, and the first becomes admin). PLEX_OWNER_USERNAME is granted
# admin on match; when it is unset, the first user to log in becomes admin (dev only).
# PLEX_ALLOWLIST=
# PLEX_OWNER_USERNAME=

# Optional operator admin SSO via Authelia OIDC.
# AUTHELIA_OIDC_ISSUER=
# AUTHELIA_OIDC_CLIENT_ID=
# AUTHELIA_OIDC_CLIENT_SECRET=
# AUTHELIA_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/authelia/callback
# AUTHELIA_ADMIN_SUBJECT=

# --- Requests ---
# Default rolling-30-day request quota for new users (blank/0 = unlimited).
DEFAULT_REQUEST_QUOTA=10
