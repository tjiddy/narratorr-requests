# narratorr-request config. Copy to .env for native dev (the server loads it via process.loadEnvFile).
# All values are host-agnostic; inside docker-compose use service hostnames, not localhost.
#
# The narratorr connection and notification channels are NOT configured here — they live
# in the admin Settings page (stored encrypted in the DB). This file is server + auth only.

# Server. PORT is the Fastify port; the Vite dev client also proxies /api to it.
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
# Bind to loopback by default. With AUTH_BYPASS on, the app refuses to bind to a
# non-loopback host (it would expose an unauthenticated admin) unless you also set
# ALLOW_INSECURE_AUTH_BYPASS=1. For real LAN/Docker use, turn AUTH_BYPASS off.
BIND_HOST=127.0.0.1
# Dev client port (Vite). Optional; defaults to 5173.
# CLIENT_PORT=5173
# Proxy target for the Vite dev client. Optional; defaults to PORT. Set only if the
# Fastify server runs on a different port than the dev client proxies to.
# SERVER_PORT=3000

# Database (libSQL file). Anchored to repo root if relative.
DATABASE_PATH=./narratorr-request.db

# Session cookie signing secret (HMAC). REQUIRED in production; dev auto-generates an
# ephemeral one if unset (sessions drop on restart — fine for local dev).
# SESSION_SECRET=

# Key for encrypting connector secrets at rest. Optional — derived from SESSION_SECRET
# when unset. Set a dedicated one to decouple connector secrets from session-secret
# rotation (rotating SESSION_SECRET without this orphans stored connector secrets).
# SETTINGS_KEY=

# --- Auth ---
# Authentication is pluggable (local password + any number of OIDC providers); WHO can
# actually request is the in-app approval queue: a new user signs in but lands `pending`
# until an admin approves them on the Users page. The FIRST user to sign in (any method)
# becomes admin + active automatically — unless BOOTSTRAP_ADMIN is set (see below).
#
# Dev shortcut: AUTH_BYPASS=1 seeds a dev admin and makes EVERY request that admin, so the
# whole app is usable with no login. Refused in production and on non-loopback binds (see
# BIND_HOST). NEVER set this in a deployment reachable by anyone but you.
AUTH_BYPASS=1

# Local email/password auth (email is the login + contact). Default ON, so a fresh
# container always has a way in (the first signup becomes admin). Set false for pure-OIDC.
# LOCAL_AUTH=true

# OIDC providers — a comma-separated list of provider ids (each lowercase [a-z0-9_], 1-32
# chars). Each id <ID> is configured with OIDC_<UPPERCASE_ID>_* vars below, and gets a
# login button + a callback at /api/auth/oidc/<id>/callback. Plex (via the bridge) and
# Authelia are just provider instances now — no special-casing.
# OIDC_PROVIDERS=plex,authelia
#
# Plex, via ghcr.io/blacktirion/plex-oidc-bridge:
# OIDC_PLEX_ISSUER=http://localhost:5556
# OIDC_PLEX_CLIENT_ID=narratorr-request
# OIDC_PLEX_CLIENT_SECRET=
# OIDC_PLEX_REDIRECT_URI=http://localhost:3000/api/auth/oidc/plex/callback
# OIDC_PLEX_LABEL=Plex
#
# Authelia (or Authentik / Keycloak / Pocket-ID / Google — same shape):
# OIDC_AUTHELIA_ISSUER=https://auth.example.com
# OIDC_AUTHELIA_CLIENT_ID=narratorr-request
# OIDC_AUTHELIA_CLIENT_SECRET=
# OIDC_AUTHELIA_REDIRECT_URI=http://localhost:3000/api/auth/oidc/authelia/callback
# OIDC_AUTHELIA_LABEL=Authelia
# Optional per-provider claim overrides (defaults: sub / preferred_username|name / email):
# OIDC_AUTHELIA_SUBJECT_CLAIM=sub
# OIDC_AUTHELIA_USERNAME_CLAIM=preferred_username
# OIDC_AUTHELIA_EMAIL_CLAIM=email
# OIDC_AUTHELIA_SCOPE=openid profile email

# Optional: pin admin to one identity as "<provider>:<subjectOrUsername>", e.g.
# "authelia:todd" or "plex:myplexuser". When set, first-user-auto-admin is DISABLED — use
# this for public/open IdPs so a stranger can't claim admin by signing in first.
# The value matches the stable OIDC `subject` OR the display username. On an OPEN IdP the
# username is user-controllable, so prefer pinning by SUBJECT there (e.g. "google:1078…").
# BOOTSTRAP_ADMIN=

# Reverse-proxy awareness for client IPs (used for auth rate-limit keying). Off by default;
# set true (trust all), a hop count, or a CIDR/IP list when behind a proxy. Same var name as
# narratorr. e.g. trust your Docker proxy network:
# TRUSTED_PROXIES=172.18.0.0/16

# --- Requests ---
# Default rolling-30-day request quota for new users (blank/0 = unlimited).
DEFAULT_REQUEST_QUOTA=10
